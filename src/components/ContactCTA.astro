---
import Section from "./Section.astro";
import Reveal from "./Reveal.astro";
---

<Section class="pb-32 sm:pb-40">
  <Reveal>
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-heading text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Let's work together
      </h2>
      <p class="mt-4 text-lg text-zinc-400">
        Interested in security research, threat intelligence, or detection
        engineering? I'm always open to interesting opportunities and
        collaborations.
      </p>
      <div class="mt-8">
        <a href="/contact" class="btn-primary inline-flex items-center gap-2">
          Get in Touch
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </Reveal>
</Section>
