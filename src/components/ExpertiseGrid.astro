---
import Section from "./Section.astro";
import Reveal from "./Reveal.astro";
import type { ExpertiseEntry } from "../data/site";

export interface Props {
  entries: ExpertiseEntry[];
}

const { entries } = Astro.props;
---

<Section id="expertise" title="Expertise" subtitle="Core competencies across offensive and defensive security domains.">
  <div class="mx-auto grid max-w-6xl gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {entries.map((entry, i) => (
      <Reveal delay={i * 80}>
        <div class="terminal-card group h-full">
          <div class="mb-3 h-1 w-10 rounded-full bg-accent/50" aria-hidden="true" />
          <h3 class="font-heading text-xl font-semibold text-white">
            {entry.title}
          </h3>
          <p class="mt-3 text-lg leading-relaxed text-zinc-400">
            {entry.description}
          </p>
        </div>
      </Reveal>
    ))}
  </div>
</Section>
