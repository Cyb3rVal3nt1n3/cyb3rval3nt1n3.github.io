---
import Section from "./Section.astro";
import Reveal from "./Reveal.astro";
import Badge from "./Badge.astro";
import { getCollection } from "astro:content";

const allEntries = await getCollection("research");
const entries = allEntries.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Section id="research" title="Research" subtitle="Deep-dive technical writeups on threat actors, vulnerabilities, and security techniques.">
  <div class="mx-auto max-w-6xl space-y-6">
    {entries.slice(0, 3).map((entry, i) => (
      <Reveal delay={i * 100}>
        <a
          href={`/research/${entry.slug}`}
          class="terminal-card group block"
        >
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <h3 class="font-heading text-xl font-semibold text-white group-hover:text-accent transition-colors">
                {entry.data.title}
              </h3>
              <p class="mt-2 text-lg leading-relaxed text-zinc-400">
                {entry.data.summary}
              </p>
            </div>
            <Badge variant="accent">{entry.data.date}</Badge>
          </div>
        </a>
      </Reveal>
    ))}
  </div>

  {entries.length > 0 && (
    <Reveal delay={Math.min(entries.length, 3) * 100}>
      <div class="mt-10 text-center">
        <a href="/research" class="btn-ghost">
          View All Research
        </a>
      </div>
    </Reveal>
  )}
</Section>
