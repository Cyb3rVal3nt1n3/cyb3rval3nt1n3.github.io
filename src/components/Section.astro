---
export interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  class?: string;
  wide?: boolean;
}

const { id, title, subtitle, class: className = "", wide = false } = Astro.props;
---

<section id={id} class:list={["section", className]}>
  <div class={wide ? "container-main" : "container-main"}>
    {title && (
      <div class="mx-auto mb-16 max-w-3xl text-center sm:mb-24">
        <h2 class="font-heading text-5xl font-bold tracking-tight text-white sm:text-6xl">
          {title}
        </h2>
        {subtitle && (
          <p class="mt-4 text-2xl text-zinc-400">{subtitle}</p>
        )}
      </div>
    )}
    <slot />
  </div>
</section>
