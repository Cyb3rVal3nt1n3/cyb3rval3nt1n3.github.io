---
export interface Props {
  name: "arrow-right" | "external" | "github" | "linkedin" | "twitter" | "globe" | "calendar" | "tag" | "menu" | "close" | "search" | "copy" | "sun" | "moon";
  class?: string;
  size?: number;
}

const { name, class: className = "", size = 20 } = Astro.props;

const icons: Record<string, string> = {
  "arrow-right": "M5 12h14M12 5l7 7-7 7",
  "external": "M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6m4-3h6v6m-11 5L21 3",
  "globe": "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z",
  "calendar": "M8 2v4m8-4v4M3 10h18m-2 0v8a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-8m4 4h.01M12 14h.01M16 14h.01M12 18h.01M16 18h.01",
  "tag": "M7 7h.01M20.59 13.41l-6.17 6.17a2 2 0 0 1-2.83 0L2 10V2h8l8.59 8.59a2 2 0 0 1 0 2.82z",
  "search": "M21 21l-6-6m2-5a7 7 0 1 1-14 0 7 7 0 0 1 14 0z",
  "copy": "M8 16H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2m-6 12h8a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2h-8a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2z",
  "close": "M18 6 6 18M6 6l12 12",
  "menu": "M3 6h18M3 12h18M3 18h18",
  "sun": "M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0z",
  "moon": "M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z",
};

const paths = icons[name];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={["shrink-0", className]}
  aria-hidden="true"
>
  <path d={paths} />
</svg>
