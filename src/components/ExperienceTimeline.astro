---
import Section from "./Section.astro";
import Reveal from "./Reveal.astro";
import type { ExperienceEntry } from "../data/site";

export interface Props {
  entries: ExperienceEntry[];
}

const { entries } = Astro.props;
---

<Section id="experience" title="Experience" subtitle="Track record of impactful security work.">
  <div class="relative mx-auto max-w-3xl">
    <div class="absolute left-[19px] top-2 h-[calc(100%-1rem)] w-px bg-border" aria-hidden="true" />

    <ol class="space-y-12">
      {entries.map((entry, i) => (
        <Reveal delay={i * 100}>
          <li class="relative pl-12">
            <div
              class="absolute left-[11px] top-2 h-4 w-4 rounded-full border-2 border-accent bg-bg"
              aria-hidden="true"
            />

            <div class="text-sm text-accent font-medium">
              {entry.period}
            </div>

            <h3 class="mt-1 font-heading text-xl font-semibold text-white">
              {entry.role}
            </h3>

            <p class="text-base text-zinc-500">
              {entry.organization}
            </p>

            <ul class="mt-3 space-y-2">
              {entry.achievements.map((achievement) => (
                <li class="flex gap-3 text-base text-zinc-400">
                  <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-zinc-600" aria-hidden="true" />
                  <span>{achievement}</span>
                </li>
              ))}
            </ul>
          </li>
        </Reveal>
      ))}
    </ol>
  </div>
</Section>
