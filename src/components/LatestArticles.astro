---
import Section from "./Section.astro";
import Reveal from "./Reveal.astro";
import Badge from "./Badge.astro";
import { getCollection } from "astro:content";

const allEntries = await getCollection("blog");
const entries = allEntries.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Section id="blog" title="Latest Articles" subtitle="Thoughts on security engineering, research, and tooling.">
  <div class="mx-auto max-w-6xl space-y-6">
    {entries.slice(0, 3).map((entry, i) => (
      <Reveal delay={i * 100}>
        <a href={`/blog/${entry.slug}`} class="terminal-card group block">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex flex-wrap items-center gap-3">
                <Badge>{entry.data.category}</Badge>
                <span class="text-xs text-zinc-600">{entry.data.date}</span>
              </div>
              <h3 class="mt-3 font-heading text-xl font-semibold text-white group-hover:text-accent transition-colors">
                {entry.data.title}
              </h3>
              <p class="mt-2 text-lg leading-relaxed text-zinc-400">
                {entry.data.summary}
              </p>
            </div>
          </div>
        </a>
      </Reveal>
    ))}
  </div>

  {entries.length > 0 && (
    <Reveal delay={Math.min(entries.length, 3) * 100}>
      <div class="mt-10 text-center">
        <a href="/blog" class="btn-ghost">
          Read All Articles
        </a>
      </div>
    </Reveal>
  )}
</Section>
