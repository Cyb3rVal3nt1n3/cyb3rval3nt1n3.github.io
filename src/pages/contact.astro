---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import Reveal from "../components/Reveal.astro";


const links = [
  {
    label: "GitHub",
    href: "https://github.com/Cyb3rVal3nt1n3",
    description: "Open-source security tools and research code.",
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/june-mwololo/",
    description: "Professional profile and connections.",
  },
  {
    label: "Twitter",
    href: "https://twitter.com/cyb3rval3nt1n3",
    description: "Security research updates and industry commentary.",
  },
];
---

<Base title="Contact">
  <Section class="pt-32 sm:pt-40">
    <div class="mx-auto max-w-3xl">
      <Reveal>
        <h1 class="font-heading text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Get in Touch
        </h1>
      </Reveal>

      <Reveal delay={100}>
        <p class="mt-4 text-xl leading-relaxed text-zinc-400">
          I'm always open to interesting conversations, research collaborations,
          and security engineering opportunities. Reach out through any of the
          channels below.
        </p>
      </Reveal>

      <Reveal delay={200}>
        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {links.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="terminal-card group">
              <h3 class="font-heading text-base font-semibold text-white group-hover:text-accent transition-colors">
                {link.label}
              </h3>
              <p class="mt-1.5 text-sm text-zinc-400">
                {link.description}
              </p>
            </a>
          ))}
        </div>
      </Reveal>
    </div>
  </Section>
</Base>
