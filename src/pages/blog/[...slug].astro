---
import Base from "../../layouts/Base.astro";
import Badge from "../../components/Badge.astro";
import ReadingProgress from "../../components/ReadingProgress.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<"blog">;
};

const { post } = Astro.props;
const { Content } = await post.render();
---

<Base title={post.data.title}>
  <ReadingProgress />

  <article class="section pt-32 sm:pt-40">
    <div class="container-main">
      <div class="mx-auto max-w-3xl">
        <div class="flex flex-wrap items-center gap-3">
          <Badge>{post.data.category}</Badge>
          <span class="text-sm text-zinc-600">{post.data.date}</span>
        </div>

        <h1 class="mt-4 font-heading text-3xl font-bold tracking-tight text-white sm:text-4xl">
          {post.data.title}
        </h1>

        <p class="mt-4 text-lg leading-relaxed text-zinc-400">
          {post.data.summary}
        </p>

        {post.data.tags && (
          <div class="mt-4 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <Badge variant="accent">{tag}</Badge>
            ))}
          </div>
        )}

        <div class="prose prose-invert mt-12 max-w-none">
          <Content />
        </div>
      </div>
    </div>
  </article>
</Base>

<script>
  document.querySelectorAll<HTMLElement>("pre code").forEach((block) => {
    const wrapper = block.closest("pre");
    if (!wrapper || wrapper.querySelector(".copy-button")) return;

    const button = document.createElement("button");
    button.className =
      "copy-button absolute top-3 right-3 rounded-md px-2 py-1 text-xs text-zinc-500 hover:text-accent bg-card border border-border transition-colors";
    button.textContent = "Copy";

    button.addEventListener("click", async () => {
      const code = block.textContent || "";
      try {
        await navigator.clipboard.writeText(code);
        button.textContent = "Copied!";
        setTimeout(() => (button.textContent = "Copy"), 2000);
      } catch {
        button.textContent = "Error";
      }
    });

    wrapper.style.position = "relative";
    wrapper.appendChild(button);
  });
</script>
