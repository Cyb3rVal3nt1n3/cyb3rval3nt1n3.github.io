---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import Reveal from "../components/Reveal.astro";
import Badge from "../components/Badge.astro";

const focusAreas = [
  "Threat Intelligence & APT Tracking",
  "Detection Engineering & Sigma Rules",
  "Red Team Operations & AD Attacks",
  "Security Tooling & Automation",
  "Vulnerability Research & Exploitation",
];
---

<Base title="About">
  <Section class="pt-32 sm:pt-40">
    <div class="mx-auto max-w-3xl">
      <Reveal>
        <h1 class="font-heading text-3xl font-bold tracking-tight text-white sm:text-4xl">
          About
        </h1>
      </Reveal>

      <Reveal delay={100}>
      <p class="mt-6 text-xl leading-relaxed text-zinc-400">
          Security researcher and detection engineer focused on building tools that
          help defenders operate at the speed of threat. I work across the full
          spectrum — from threat intelligence and APT tracking to offensive security
          research and detection engineering.
        </p>

      <p class="mt-4 text-xl leading-relaxed text-zinc-400">
          My work combines deep technical implementation with operational
          context — understanding not just how an attack works, but how to detect it
          reliably, automate the response, and communicate the risk to stakeholders.
        </p>
      </Reveal>

      <Reveal delay={300}>
        <div class="mt-10">
          <h2 class="font-heading text-xl font-semibold text-white">Focus Areas</h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {focusAreas.map((area) => (
              <Badge variant="accent">{area}</Badge>
            ))}
          </div>
        </div>
      </Reveal>

      <Reveal delay={400}>
        <div class="mt-10">
          <h2 class="font-heading text-xl font-semibold text-white">Why CyberValentine</h2>
          <p class="mt-6 text-xl leading-relaxed text-zinc-400">
            Because security is a relationship — between tools and analysts, between
            detection and response, between understanding a threat and stopping it.
            Every tool I build is designed to strengthen that connection.
          </p>
        </div>
      </Reveal>
    </div>
  </Section>
</Base>
