---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
---

<Base title="Not Found">
  <div class="flex min-h-[60vh] items-center justify-center">
    <div class="text-center">
      <p class="text-8xl font-bold text-accent">404</p>
      <h1 class="mt-4 font-heading text-2xl font-bold text-white">Page not found</h1>
      <p class="mt-2 text-zinc-400">The page you're looking for doesn't exist or has been moved.</p>
      <div class="mt-8">
        <Button href="/">Go Home</Button>
      </div>
    </div>
  </div>
</Base>
