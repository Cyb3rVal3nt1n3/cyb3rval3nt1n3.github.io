---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
---

<Base title="Search">
  <Section class="pt-32 sm:pt-40">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-heading text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Search
      </h1>

      <div class="relative mt-6">
        <input
          id="search-input"
          type="search"
          placeholder="Search projects, research, articles..."
          class="w-full rounded-xl border border-border bg-card px-4 py-3 pl-12 text-sm text-white placeholder-zinc-500 outline-none transition-colors focus:border-accent"
          autofocus
        />
        <svg
          class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-zinc-500"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="11" cy="11" r="8" />
          <path d="M21 21l-4.35-4.35" />
        </svg>
      </div>

      <div id="results" class="mt-8 space-y-4">
        <p class="text-sm text-zinc-500">Type to start searching...</p>
      </div>
    </div>
  </Section>
</Base>

<script>
  interface SearchItem {
    title: string;
    description: string;
    url: string;
    type: "project" | "research" | "blog";
  }

  const input = document.getElementById("search-input") as HTMLInputElement;
  const results = document.getElementById("results")!;

  let index: SearchItem[] = [];

  async function loadIndex() {
    try {
      const res = await fetch("/search.json");
      index = await res.json();
    } catch {
      results.innerHTML = `<p class="text-sm text-zinc-500">Failed to load search index.</p>`;
    }
  }

  function search(query: string): SearchItem[] {
    const q = query.toLowerCase();
    return index.filter(
      (item) =>
        item.title.toLowerCase().includes(q) ||
        item.description.toLowerCase().includes(q)
    ).slice(0, 20);
  }

  function render(items: SearchItem[]) {
    if (items.length === 0) {
      results.innerHTML = `<p class="text-sm text-zinc-500">No results found.</p>`;
      return;
    }

    results.innerHTML = items
      .map(
        (item) => `
      <a href="${item.url}" class="terminal-card group block">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-2">
              <span class="rounded bg-accent/10 px-2 py-0.5 text-xs text-accent">${item.type}</span>
            </div>
            <h3 class="mt-2 font-heading text-base font-semibold text-white group-hover:text-accent transition-colors">
              ${item.title}
            </h3>
            <p class="mt-1 text-sm text-zinc-400">${item.description}</p>
          </div>
        </div>
      </a>
    `
      )
      .join("");
  }

  input?.addEventListener("input", () => {
    const query = input.value.trim();
    if (query.length === 0) {
      results.innerHTML = `<p class="text-sm text-zinc-500">Type to start searching...</p>`;
      return;
    }
    render(search(query));
  });

  loadIndex();
</script>
