---
import Base from "../../layouts/Base.astro";
import Section from "../../components/Section.astro";
import Reveal from "../../components/Reveal.astro";
import Badge from "../../components/Badge.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("research");
entries.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Base title="Research">
  <Section class="pt-32 sm:pt-40" title="Research" subtitle="Deep-dive technical writeups on threat actors, vulnerabilities, and security techniques.">
    <div class="mx-auto max-w-6xl space-y-6">
      {entries.map((entry, i) => (
        <Reveal delay={i * 100}>
          <a href={`/research/${entry.slug}`} class="terminal-card group block">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <h3 class="font-heading text-xl font-semibold text-white group-hover:text-accent transition-colors">
                  {entry.data.title}
                </h3>
                <p class="mt-2 text-lg leading-relaxed text-zinc-400">
                  {entry.data.summary}
                </p>
                {entry.data.tags && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {entry.data.tags.map((tag) => (
                      <Badge>{tag}</Badge>
                    ))}
                  </div>
                )}
              </div>
              <Badge variant="accent">{entry.data.date}</Badge>
            </div>
          </a>
        </Reveal>
      ))}
    </div>

    {entries.length === 0 && (
      <p class="text-center text-zinc-500">No research yet.</p>
    )}
  </Section>
</Base>
